# name: test/sql/opendal_secret.test
# description: OpenDAL backend secret registration and default scopes
# group: [sql]

require duckdb_opendalfs

statement ok
SET allow_persistent_secrets=false;

statement ok
CREATE SECRET opendal_s3_test (
	TYPE opendal_s3,
	ACCESS_KEY_ID 'access-key',
	SECRET_ACCESS_KEY 'secret-key',
	REGION 'us-east-1'
);

query III
SELECT name, type, scope FROM duckdb_secrets() WHERE name='opendal_s3_test';
----
opendal_s3_test	opendal_s3	['s3://', 's3a://', 's3n://']

query I
SELECT secret_string LIKE '%secret-key%' FROM duckdb_secrets() WHERE name='opendal_s3_test';
----
false

statement ok
CREATE SECRET opendal_gcs_test (
	TYPE opendal_gcs,
	TOKEN 'token'
);

query II
SELECT type, scope FROM duckdb_secrets() WHERE name='opendal_gcs_test';
----
opendal_gcs	['gcs://', 'gs://']
